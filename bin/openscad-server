#!/usr/bin/env python3
"""Lightweight HTTP server wrapping native OpenSCAD CLI.

Start once in a regular terminal (outside any sandbox). The pipeline's
openscad-local wrapper talks to this via localhost.

Usage:
    bin/openscad-server              # default port 9876
    bin/openscad-server --port 9999  # custom port
    OPENSCAD_BIN=/path/to/openscad bin/openscad-server
"""

import argparse
import json
import os
import subprocess
import sys
import tempfile
from http.server import HTTPServer, BaseHTTPRequestHandler

OPENSCAD_BIN = os.environ.get(
    "OPENSCAD_BIN", "/opt/homebrew/bin/openscad"
)


class Handler(BaseHTTPRequestHandler):
    def do_POST(self):
        if self.path == "/render":
            self._handle_render()
        elif self.path == "/health":
            self._json_response(200, {"ok": True})
        else:
            self._json_response(404, {"error": "not found"})

    def do_GET(self):
        if self.path == "/health":
            self._json_response(200, {"ok": True, "openscad": OPENSCAD_BIN})
        else:
            self._json_response(404, {"error": "not found"})

    def _handle_render(self):
        try:
            length = int(self.headers.get("Content-Length", 0))
            body = json.loads(self.rfile.read(length))
        except Exception as e:
            self._json_response(400, {"error": "bad request: %s" % e})
            return

        scad_path = body.get("scad_path")
        output_path = body.get("output_path")
        extra_args = body.get("extra_args", [])

        if not scad_path or not output_path:
            self._json_response(400, {"error": "scad_path and output_path required"})
            return

        if not os.path.exists(scad_path):
            self._json_response(400, {"error": "scad_path not found: %s" % scad_path})
            return

        cmd = [OPENSCAD_BIN] + extra_args + ["-o", output_path, scad_path]
        try:
            r = subprocess.run(cmd, capture_output=True, text=True, timeout=300)
            ok = r.returncode == 0 and os.path.exists(output_path)
            resp = {
                "ok": ok,
                "returncode": r.returncode,
                "stdout": r.stdout[-2000:] if r.stdout else "",
                "stderr": r.stderr[-2000:] if r.stderr else "",
            }
            self._json_response(200 if ok else 500, resp)
        except subprocess.TimeoutExpired:
            self._json_response(500, {"ok": False, "error": "timeout (300s)"})
        except Exception as e:
            self._json_response(500, {"ok": False, "error": str(e)})

    def _json_response(self, code, obj):
        body = json.dumps(obj).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, fmt, *args):
        sys.stderr.write("[openscad-server] %s\n" % (fmt % args))


def main():
    parser = argparse.ArgumentParser(description="OpenSCAD render server")
    parser.add_argument("--port", type=int, default=9876)
    args = parser.parse_args()

    r = subprocess.run([OPENSCAD_BIN, "--version"], capture_output=True, text=True)
    version = (r.stdout + r.stderr).strip()
    print("openscad-server: %s on port %d" % (version, args.port), flush=True)
    print("openscad-server: binary = %s" % OPENSCAD_BIN, flush=True)
    print("openscad-server: ready", flush=True)

    server = HTTPServer(("127.0.0.1", args.port), Handler)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nopenscad-server: stopped", flush=True)
        server.server_close()


if __name__ == "__main__":
    main()
